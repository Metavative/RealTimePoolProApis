PORT=4000
NODE_ENV=development

# Database
MONGO_URI=
MONGODB_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES=7d

# CORS
CLIENT_URL=http://localhost:3000

# SMTP (email OTP / notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
EMAIL_DISABLED=false

# Twilio Verify (phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# Payments v2 foundation (safe toggle)
FEATURE_PAYMENTS_V2=false
PAYMENTS_PROVIDER=MOCK
PAYMENTS_ENVIRONMENT=SANDBOX
# Issue REAL gateway refunds (return money to the player's card) when a paid
# tournament entry is refunded. OFF = internal ledger reversal only (no real
# money moves), matching prior behaviour. Turn ON only with a live provider
# whose refundPayment() is implemented (MOCK is fine for testing).
FEATURE_PROVIDER_REFUNDS=false
# Let organisers request a payout of their accrued ORGANIZER_BALANCE (moves it to
# a hold; settlement is an admin/back-office step). Requires FEATURE_PAYMENTS_V2.
FEATURE_ORGANIZER_PAYOUTS=false
PAYMENTS_WEBHOOK_SECRET=
PAYMENTS_PLATFORM_FEE_BPS=0
MYPOS_WEBHOOK_SECRET=

# myPOS Checkout / Online Payments v1.4 (fill when the merchant account is ready).
# These are the CHECKOUT credentials (merchant wallet + RSA keypair) — NOT the
# old Partner/OAuth API keys. Provider stays inert until these are set.
MYPOS_WALLET_NUMBER=
MYPOS_SID=
MYPOS_KEY_INDEX=1
# Merchant RSA private key (PEM). Newlines may be stored as literal \n.
MYPOS_PRIVATE_KEY=
# myPOS public certificate (PEM) used to verify the IPCPurchaseNotify signature.
MYPOS_PUBLIC_CERT=
# TEST (sandbox: /vmp/checkout-test) or PRODUCTION (/vmp/checkout).
MYPOS_ENVIRONMENT=TEST
MYPOS_LANGUAGE=EN
# Currency the myPOS MOBILE SDK charges in — MUST equal your myPOS store's
# currency (and the app wallet currency). Wallet top-up intents are forced to
# this currency when PAYMENTS_PROVIDER=MYPOS so the intent can't diverge from
# what's charged on the card. Default GBP.
MYPOS_MOBILE_CURRENCY=GBP
# Public https origin myPOS redirects/notifies back to (Railway URL, no port).
# Falls back to PUBLIC_BASE_URL / the request host if unset.
MYPOS_RETURN_BASE_URL=

# Store checkout migration
FEATURE_STORE_CHECKOUT_V2=false
STORE_CHECKOUT_RESERVATION_MINUTES=20

# Level economy v2
FEATURE_LEVEL_ECONOMY_V2=false
LEVEL_MAX_SUPPORTED=20
LEVEL_MATCH_COMMISSION_BPS=0
LEVEL_CURRENCY=GBP

# Matchmaking automation v2
FEATURE_MATCHMAKING_V2=false
MATCHMAKING_DEFAULT_RADIUS_KM=15
MATCHMAKING_MAX_RADIUS_KM=50
MATCHMAKING_LIVE_TTL_SECONDS=120

# Tournament economy v2
FEATURE_TOURNAMENT_ECONOMY_V2=false

# Ledger↔earnings unification (USER_WALLET ledger = source of truth for spendable
# balance). Keep OFF until the U3 backfill has run against the target DB. When ON,
# 1v1/tournament winnings post to the ledger and availableBalance becomes a cache.
FEATURE_LEDGER_UNIFIED=false

# Referral v2
FEATURE_REFERRAL_V2=false
REFERRAL_COMMISSION_BPS=5000
REFERRAL_MIN_PAYOUT_MINOR=1

# Dispute v2
FEATURE_DISPUTE_V2=false
DISPUTE_MATCH_COMMISSION_RATE=0.10

# Insights + reliability v2
FEATURE_INSIGHTS_V2=false
FEATURE_ACHIEVEMENTS_V2=false
LOG_SLOW_REQUESTS=true
SLOW_REQUEST_THRESHOLD_MS=1200
